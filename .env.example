# =============================================================================
# Agentarium — 環境変数テンプレート
# このファイルをコピーして .env を作成し、各値を設定してください。
# cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# エージェント基本設定
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO                     # DEBUG / INFO / WARNING / ERROR

# -----------------------------------------------------------------------------
# Ollama（LLM ローカル実行）
# Docker 外から Ollama を使う場合は http://host.docker.internal:11434
# -----------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# -----------------------------------------------------------------------------
# Qdrant（ベクトルDB）
# Docker Compose で起動する場合はデフォルト値のままでOK
# -----------------------------------------------------------------------------
QDRANT_HOST=localhost
QDRANT_PORT=6333

# -----------------------------------------------------------------------------
# Playwright ブラウザ（rebrowser-playwright コンテナ）
# Docker Compose で起動する場合はデフォルト値のままでOK
# -----------------------------------------------------------------------------
BROWSER_REMOTE_URL=http://localhost:9222

# -----------------------------------------------------------------------------
# Discord（Phase 2〜）
# Webhook URL: Discord サーバー設定 → テキストチャンネル → 連携サービス → ウェブフック
# -----------------------------------------------------------------------------
DISCORD_WEBHOOK_URL=             # 例: https://discord.com/api/webhooks/123456789/xxxxxxxxxxx
DISCORD_CHANNEL_GENERAL=         # チャンネル ID（将来の Bot API 用）

# -----------------------------------------------------------------------------
# Phase 2 AgentLoop 有効化
# true にするとルールベース巡回（PatrolScheduler）に加えて
# LLM 駆動の自律ループ（AgentLoop）が並列起動します
# -----------------------------------------------------------------------------
ENABLE_AGENT_LOOP=false

# -----------------------------------------------------------------------------
# X（旧 Twitter）— Phase 3 以降
# -----------------------------------------------------------------------------
# X_USERNAME=
# X_PASSWORD=
# X_COOKIE_PATH=data/browser-profile/x_cookies.json

# -----------------------------------------------------------------------------
# ダッシュボード（Phase 3）
# -----------------------------------------------------------------------------
# DASHBOARD_PORT=3000
# DASHBOARD_API_PORT=8080
