# Agentarium 環境変数テンプレート
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# ログレベル
LOG_LEVEL=INFO

# Ollama（ホスト直接実行の場合 host.docker.internal を使用）
OLLAMA_BASE_URL=http://localhost:11434

# Qdrant（Docker Compose で起動する場合はデフォルト値のまま）
QDRANT_HOST=localhost

# ブラウザ CDP エンドポイント（Docker Compose の browser コンテナ）
BROWSER_REMOTE_URL=http://localhost:9222

# Discord（Phase 2 で追加）
# DISCORD_TOKEN=

# X / Twitter（Phase 1: 読取のみ。トークン不要）
# X_USERNAME=
# X_PASSWORD=  # セッション維持に使用。.env に記載し git に含めないこと
